    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n    o.id, o.quantity, o.start_count, o.service_id, o.link, o.user_id ,\n    s.min_qty as main_min, s.refill_service_id,\n    s2.min_qty as refill_min, s2.price as refill_cost\nFROM orders o\nJOIN services s ON o.service_id = s.id\nLEFT JOIN services s2 ON s.refill_service_id = s2.id\nWHERE o.id = $1;",
        "options": {
          "queryReplacement": "={{ $json.body.order_id }}"
        }
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        -128,
        -48
      ],
      "id": "a7e2c098-0e4b-49f5-99d5-7e43691b1a3e",
      "name": "Execute a SQL query",
      "credentials": {
        "postgres": {
          "id": "Go2VCJWsQKpZt8vQ",
          "name": "Postgres account 2"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const order = $input.first().json;\nconst currentCount = parseInt($('Webhook').first().json.body.current_count);\n\n// 1. คำนวณยอดที่ต้องมี (Target)\nconst targetCount = parseInt(order.start_count) + parseInt(order.quantity);\n\n// 2. คำนวณยอดที่หายไป (Missing)\nlet missingQty = targetCount - currentCount;\n\nif (missingQty <= 0) {\n    return { json: { status: \"NO_REFILL_NEEDED\", msg: \"ยอดครบหรือเกินแล้ว\" } };\n}\n\n// 3. เลือก Service ที่จะใช้ซ่อม (The Selection Logic)\nlet serviceToUse = order.service_id; // ค่าเริ่มต้น: ใช้ตัวเดิมซ่อม\nlet isRefillOrder = true;\n\n// ถ้าบริการเดิมมีขั้นต่ำสูงกว่ายอดที่หาย (เช่น หาย 10 แต่ขั้นต่ำ 100)\n// และเรามี Refill Service เตรียมไว้\nif (missingQty < order.main_min && order.refill_service_id) {\n    serviceToUse = order.refill_service_id; // สลับไปใช้ตัวซ่อมยอดน้อย\n    \n    // เช็คอีกทีว่าถึงขั้นต่ำตัวซ่อมไหม (เช่น ตัวซ่อมขั้นต่ำ 5 แต่หาย 10 -> ผ่าน)\n    if (missingQty < order.refill_min) {\n        // ถ้ายอดน้อยมากๆ จริงๆ อาจต้องปัดขึ้นให้เท่าขั้นต่ำ\n        missingQty = order.refill_min; \n    }\n} else if (missingQty < order.main_min) {\n    // กรณีไม่มีตัวสำรอง แต่ยอดไม่ถึงขั้นต่ำ -> จำใจต้องปัดขึ้นให้เท่าขั้นต่ำของตัวหลัก\n    // (ยอมขาดทุนเพิ่มนิดหน่อย เพื่อรักษาลูกค้า)\n    missingQty = order.main_min;\n}\n\nreturn {\n    json: {\n        service_id: serviceToUse,\n        link: order.link,\n        quantity: missingQty,\n        user_id: $input.first().json.user_id,\n        action: \"CREATE_REPAIR_ORDER\",\n        original_order_id: order.id,\n        price: 0, // ฟรีสำหรับลูกค้า\n        remark: `Refill for Order #${order.id} (Missing: ${missingQty})`,\n        dependency_order_id: null\n    }\n};"
      },
